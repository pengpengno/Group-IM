# Build stage
FROM node:20-alpine AS build

# Build-time arguments to inject backend addresses
ARG API_BASE
ARG TCP_HOST
ARG TCP_PORT

WORKDIR /app

# Set environment variables for the build process
ENV NODE_ENV=production
ENV API_BASE=$API_BASE
ENV TCP_HOST=$TCP_HOST
ENV TCP_PORT=$TCP_PORT

# Copy necessary files
# Assumes docker build is run from the project root
COPY common/ /app/common/
COPY Group-app/Group-Electronjs/ /app/Group-app/Group-Electronjs/

WORKDIR /app/Group-app/Group-Electronjs

# Install dependencies required for the build stage, including devDependencies
RUN npm install --include=dev

# Build the web assets
# This will use the new semantic command and inject environmental variables via Webpack DefinePlugin
RUN npm run web:build

# Final stage: Minimal image to hold only the built assets
FROM alpine:latest
WORKDIR /app
# Copy the built files from the previous stage
COPY --from=build /app/Group-app/Group-Electronjs/dist-web /dist-web

# This container provides the files, it's typically used as a source for shared volumes or manual extraction
CMD ["sh", "-c", "echo 'Frontend assets ready at /dist-web'; sleep infinity"]
